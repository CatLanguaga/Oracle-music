# --- API keys ---
# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Last.fm (https://www.last.fm/api/account/create)
LASTFM_API_KEY=

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- App ---
APP_ENV=dev              # dev | prod
LOG_LEVEL=INFO

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
SESSION_TTL_MINUTES=30

# --- Storage ---
# DEV: SQLite local + fakeredis in-memory (sin docker)
DATABASE_URL=sqlite+aiosqlite:///./nyota.db
REDIS_URL=memory://

# PROD (Coolify): cambiar a postgres + redis
# DATABASE_URL=postgresql+asyncpg://nyota:nyota@postgres:5432/nyota
# REDIS_URL=redis://redis:6379/0
